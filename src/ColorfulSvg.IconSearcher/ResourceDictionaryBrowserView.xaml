<UserControl x:Class="ColorfulSvg.IconSearcher.ResourceDictionaryBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Microsoft YaHei UI">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FilePathTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#475569"
                           Text="尚未选择资源文件"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="2"
                        Padding="10,6"
                        Click="OpenResourceFile_Click"
                        Content="打开 XAML" />

                <Border Grid.Column="4"
                        Padding="10,5"
                        Background="#E8F0FF"
                        CornerRadius="999"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="CountTextBlock"
                               Foreground="#0F5FFF"
                               FontWeight="SemiBold"
                               Text="0 个图标" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="12"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <TextBox x:Name="SearchTextBox"
                     Padding="12,8"
                     TextChanged="SearchTextBox_TextChanged"
                     FontSize="14"
                     ToolTip="按空格分隔多个关键词，例如：add edit sync" />
        </Border>

        <Border Grid.Row="4"
                Padding="10"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <TextBlock x:Name="EmptyStateTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="#64748B"
                           Text="打开一个导出的 XAML 资源文件。" />

                <ScrollViewer x:Name="ResourceScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <ItemsControl x:Name="ResourceItemsControl"
                                  Width="{Binding ElementName=ResourceScrollViewer, Path=ActualWidth}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="148"
                                        Margin="0,0,8,8"
                                        Padding="10"
                                        Background="#FBFCFE"
                                        BorderBrush="#E6EBF4"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Button Padding="0"
                                            Click="CopyKey_Click"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <StackPanel>
                                            <Border Width="64"
                                                    Height="64"
                                                    HorizontalAlignment="Center"
                                                    Background="#F1F5F9"
                                                    BorderBrush="#DCE4EF"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Image Width="30"
                                                       Height="30"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Source="{Binding Image}" />
                                            </Border>

                                            <TextBlock Margin="0,10,0,0"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#0F172A"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Key}"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="42" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
