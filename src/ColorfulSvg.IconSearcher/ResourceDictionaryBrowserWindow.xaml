<Window x:Class="ColorfulSvg.IconSearcher.ResourceDictionaryBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorfulSvg.IconSearcher"
        Title="导出资源浏览"
        Icon="Assets/App.ico"
        Width="980"
        Height="760"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FilePathTextBlock"
                               VerticalAlignment="Center"
                               Foreground="#475569"
                               Text="尚未选择资源文件"
                               TextTrimming="CharacterEllipsis" />

                    <Button Grid.Column="2"
                            Padding="10,6"
                            Click="OpenResourceFile_Click"
                            Background="#0F5FFF"
                            BorderThickness="0"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Content="打开 XAML" />

                    <Border Grid.Column="4"
                            Padding="10,5"
                            Background="#E8F0FF"
                            CornerRadius="999"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CountTextBlock"
                                   Foreground="#0F5FFF"
                                   FontWeight="SemiBold"
                                   Text="0 个图标" />
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="12"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Padding="12,8"
                         TextChanged="SearchTextBox_TextChanged"
                         BorderBrush="#DCE4EF"
                         BorderThickness="1"
                         FontSize="14"
                         ToolTip="按空格分隔多个关键词，例如：add edit sync" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#0F172A"
                           FontWeight="SemiBold"
                           Text="图标大小" />

                <Slider Grid.Column="4"
                        Minimum="24"
                        Maximum="160"
                        TickFrequency="4"
                        IsSnapToTickEnabled="True"
                        Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ResourceDictionaryBrowserWindow}}, Path=IconPreviewSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6"
                           VerticalAlignment="Center"
                           Foreground="#475569"
                           FontWeight="SemiBold"
                           Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ResourceDictionaryBrowserWindow}}, Path=IconPreviewSize, StringFormat={}{0:0}}" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="10"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <TextBlock x:Name="EmptyStateTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="#64748B"
                           Text="打开一个导出的 XAML 资源文件。" />

                <ScrollViewer x:Name="ResourceScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <ItemsControl x:Name="ResourceItemsControl"
                                  Width="{Binding ElementName=ResourceScrollViewer, Path=ActualWidth}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ResourceDictionaryBrowserWindow}}, Path=ItemCardWidth}"
                                        Margin="0,0,8,8"
                                        Padding="12"
                                        Background="#FBFCFE"
                                        BorderBrush="#E6EBF4"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        ToolTip="{Binding Key}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="CopyKey_Click">
                                    <StackPanel>
                                        <Border Padding="10"
                                                HorizontalAlignment="Center"
                                                Background="White"
                                                BorderBrush="#DCE4EF"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ResourceDictionaryBrowserWindow}}, Path=IconPreviewSize}"
                                                  Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ResourceDictionaryBrowserWindow}}, Path=IconPreviewSize}">
                                                <Image Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Source="{Binding PreviewImage}" />
                                            </Grid>
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#0F172A"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Key}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="42" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
