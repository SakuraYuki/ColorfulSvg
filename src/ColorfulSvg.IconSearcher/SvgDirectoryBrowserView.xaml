<UserControl x:Class="ColorfulSvg.IconSearcher.SvgDirectoryBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorfulSvg.IconSearcher"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Microsoft YaHei UI">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="DirectoryPathTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#475569"
                           Text="尚未选择 SVG 目录或文件"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="2"
                        Padding="10,6"
                        Click="OpenDirectory_Click"
                        Content="打开目录" />

                <Button Grid.Column="4"
                        Padding="10,6"
                        Click="OpenFiles_Click"
                        Content="选择文件" />

                <Border Grid.Column="6"
                        Padding="10,5"
                        Background="#E8F0FF"
                        CornerRadius="999"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="CountTextBlock"
                               Foreground="#0F5FFF"
                               FontWeight="SemiBold"
                               Text="0 个图标" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="12"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Padding="12,8"
                         TextChanged="SearchTextBox_TextChanged"
                         FontSize="14"
                         ToolTip="按空格分隔多个关键词，例如：folder outlined" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#0F172A"
                           FontWeight="SemiBold"
                           Text="图标大小" />

                <Slider Grid.Column="4"
                        Minimum="16"
                        Maximum="128"
                        TickFrequency="4"
                        IsSnapToTickEnabled="True"
                        Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SvgDirectoryBrowserView}}, Path=IconPreviewSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6"
                           VerticalAlignment="Center"
                           Foreground="#475569"
                           FontWeight="SemiBold"
                           Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SvgDirectoryBrowserView}}, Path=IconPreviewSize, StringFormat={}{0:0}}" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="10"
                Background="White"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <TextBlock x:Name="EmptyStateTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="#64748B"
                           Text="打开一个包含 SVG 图标的目录，或选择多个 SVG 文件。" />

                <ScrollViewer x:Name="ResourceScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <ItemsControl x:Name="ResourceItemsControl"
                                  Width="{Binding ElementName=ResourceScrollViewer, Path=ActualWidth}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="188"
                                        Margin="0,0,8,8"
                                        Padding="12"
                                        Background="#FBFCFE"
                                        BorderBrush="#E6EBF4"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        ToolTip="{Binding FilePath}">
                                    <StackPanel>
                                        <Border Padding="10"
                                                HorizontalAlignment="Center"
                                                Background="White"
                                                BorderBrush="#DCE4EF"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SvgDirectoryBrowserView}}, Path=IconPreviewSize}"
                                                  Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SvgDirectoryBrowserView}}, Path=IconPreviewSize}">
                                                <Image Stretch="Uniform"
                                                       Source="{Binding Image}" />
                                            </Grid>
                                        </Border>

                                        <TextBlock Margin="0,10,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#0F172A"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="42" />

                                        <TextBlock Margin="0,6,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   Text="{Binding RelativeDirectory}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="34" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
